# Copy to .env and fill. NEVER commit .env. Verify keys by length/hash, not by printing.
# Polymarket: public Gamma/CLOB/Data APIs need no key for reads.
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
POLYMARKET_DATA_BASE=https://data-api.polymarket.com

# Kalshi (trade API is read-usable for market data; key optional for higher limits)
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_API_PRIVATE_KEY_PATH=

# Neutral ground-truth results source (choose one; do NOT grade against venue settlement)
PANDASCORE_TOKEN=
# Oracle's Elixir is a file download; no key.

# Optional historical archives (validate with throwaway key BEFORE purchase)
POLYMARKETDATA_KEY=
KALSHI_HISTORICAL_KEY=
